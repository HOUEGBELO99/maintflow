# ──────────────────────────────────────────────────────────────────────────
# MaintFlow — environment template. Copy to `.env` and fill in.
# NEVER commit a real `.env`. Secrets live in the deploy platform / Supabase.
# ──────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# ── Database (local docker = Supabase Postgres in prod) ───────────────────
# Local:  postgresql://maintflow:maintflow@localhost:5432/maintflow?schema=public
# Supabase: use the "Connection string" (use the pooled 6543 URL for the app,
#           and the direct 5432 URL for Prisma migrations).
DATABASE_URL=postgresql://maintflow:maintflow@localhost:5432/maintflow?schema=public
DIRECT_URL=postgresql://maintflow:maintflow@localhost:5432/maintflow?schema=public

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, NEVER in the client
SUPABASE_JWT_SECRET=your-jwt-secret               # used by the API to verify access tokens
SUPABASE_STORAGE_BUCKET=maintflow-files

# ── Redis (BullMQ) — local docker = Upstash in prod ───────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ISSUER=https://YOUR-PROJECT.supabase.co/auth/v1
ACCESS_TOKEN_AUDIENCE=authenticated

# ── Web (Next.js public vars — exposed to the browser, keep them non-secret) ─
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Mobile (Flutter --dart-define, mirrored here for reference) ───────────
# flutter run --dart-define=API_URL=... --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=...

# ── Business config (defaults from the prototype seed) ────────────────────
DEFAULT_HOURLY_DOWNTIME_COST=850
DEFAULT_CURRENCY=EUR
