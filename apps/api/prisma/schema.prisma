// ─────────────────────────────────────────────────────────────────────────────
// MaintFlow — Prisma schema
// Translated from the prototype domain model (data.js SEED).
// Target: Supabase PostgreSQL. Auth users live in Supabase `auth.users`;
// the `User` table below is the application profile, keyed by the Supabase UID.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  chef_maintenance
  chef_atelier
  technicien
  operateur
}

enum UserStatus {
  active
  inactive
}

enum MachineState {
  ok
  fault
  maintenance
}

enum Criticality {
  high
  medium
  low
}

enum FaultType {
  mecanique
  electrique
  hydraulique
  logiciel
}

enum FaultSeverity {
  critical
  medium
  low
}

enum FaultStatus {
  pending
  in_progress
  resolved
}

enum InterventionKind {
  corrective
  preventive
}

enum InterventionStatus {
  planned
  in_progress
  completed
  cancelled
}

enum NotificationLevel {
  critical
  warning
  info
}

enum InvitationStatus {
  pending
  accepted
  revoked
}

// ── Tenancy ──────────────────────────────────────────────────────────────────
// A Site is the multi-tenant boundary. Every row hangs off a Site so RLS can
// isolate data per customer/plant. Workshops group machines within a site.

model Site {
  id                 String @id @default(uuid()) @db.Uuid
  name               String
  // Business config (defaults from the prototype: 850 €/h, EUR).
  hourlyDowntimeCost Int    @default(850)
  currency           String @default("EUR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  machines      Machine[]
  faults        Fault[]
  interventions Intervention[]
  parts         Part[]
  planRules     PlanRule[]
  notifications Notification[]
  invitations   Invitation[]

  @@map("sites")
}

// ── Identity / RBAC ──────────────────────────────────────────────────────────

model User {
  // Equals the Supabase auth user id (auth.users.id).
  id        String     @id @db.Uuid
  siteId    String     @db.Uuid
  name      String
  email     String     @unique
  role      UserRole
  workshop  String
  status    UserStatus @default(active)
  color     String?
  initials  String?
  lastLogin DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site                  Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  technicianProfile     Technician?
  reportedFaults        Fault[]        @relation("FaultReporter")
  assignedInterventions Intervention[] @relation("InterventionTechnician")
  invitationsSent       Invitation[]   @relation("InvitedBy")

  @@index([siteId])
  @@index([role])
  @@map("users")
}

model Technician {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @db.Uuid
  specialties   String[] @default([])
  available     Boolean  @default(true)
  // Performance snapshot (recomputed by a scheduled job).
  onTime        Int      @default(0)
  rating        Float    @default(0)
  doneThisMonth Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("technicians")
}

model Invitation {
  id          String           @id @default(uuid()) @db.Uuid
  siteId      String           @db.Uuid
  email       String
  role        UserRole
  workshop    String
  invitedById String           @db.Uuid
  status      InvitationStatus @default(pending)
  sentAt      DateTime         @default(now())

  site      Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([siteId, status])
  @@map("invitations")
}

// ── Assets ───────────────────────────────────────────────────────────────────

model Machine {
  id            String       @id @default(uuid()) @db.Uuid
  siteId        String       @db.Uuid
  code          String // e.g. MCH-001
  name          String
  type          String // compresseur, convoyeur, pompe, ...
  workshop      String
  installedAt   DateTime     @db.Date
  state         MachineState @default(ok)
  runtime       Int          @default(0) // operating hours
  criticality   Criticality  @default(medium)
  hourlyCost    Int          @default(0) // € per hour of downtime for this machine
  lifespanYears Int          @default(10)
  posX          Int          @default(0)
  posY          Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  faults        Fault[]
  interventions Intervention[]
  planRules     PlanRule[]

  @@unique([siteId, code])
  @@index([siteId, state])
  @@index([siteId, workshop])
  @@map("machines")
}

// ── Faults ───────────────────────────────────────────────────────────────────

model Fault {
  id           String        @id @default(uuid()) @db.Uuid
  siteId       String        @db.Uuid
  machineId    String        @db.Uuid
  type         FaultType
  description  String
  severity     FaultSeverity
  status       FaultStatus   @default(pending)
  rootCause    String?
  reportedById String        @db.Uuid
  reportedAt   DateTime      @default(now())
  takenAt      DateTime? // when a technician took it in charge
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  machine      Machine       @relation(fields: [machineId], references: [id], onDelete: Cascade)
  reportedBy   User          @relation("FaultReporter", fields: [reportedById], references: [id])
  intervention Intervention? @relation("FaultIntervention")
  attachments  Attachment[]

  @@index([siteId, status])
  @@index([machineId])
  @@index([severity, status])
  @@map("faults")
}

// ── Interventions ────────────────────────────────────────────────────────────

model Intervention {
  id            String             @id @default(uuid()) @db.Uuid
  siteId        String             @db.Uuid
  machineId     String             @db.Uuid
  technicianId  String             @db.Uuid
  kind          InterventionKind
  description   String
  scheduledFor  DateTime           @db.Date
  duration      Float // planned hours
  status        InterventionStatus @default(planned)
  linkedFaultId String?            @unique @db.Uuid
  planRuleId    String?            @db.Uuid

  // Checklist stored as JSON: [{ label: string, done: boolean }]
  checklist Json @default("[]")

  // Closure data
  actualDuration Float?
  rating         Int? // 1..5
  signedBy       String?
  startedAt      DateTime?
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  machine     Machine      @relation(fields: [machineId], references: [id], onDelete: Cascade)
  technician  User         @relation("InterventionTechnician", fields: [technicianId], references: [id])
  linkedFault Fault?       @relation("FaultIntervention", fields: [linkedFaultId], references: [id])
  planRule    PlanRule?    @relation(fields: [planRuleId], references: [id])
  partsUsed   PartUsage[]
  attachments Attachment[]

  @@index([siteId, status])
  @@index([technicianId, status])
  @@index([machineId])
  @@index([scheduledFor])
  @@map("interventions")
}

// ── Inventory ────────────────────────────────────────────────────────────────

model Part {
  id       String   @id @default(uuid()) @db.Uuid
  siteId   String   @db.Uuid
  name     String
  ref      String
  stock    Int      @default(0)
  min      Int      @default(0)
  location String
  unitCost Int      @default(0)
  forTypes String[] @default([]) // machine types this part fits

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site   Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  usages PartUsage[]

  @@unique([siteId, ref])
  @@index([siteId])
  @@map("parts")
}

// Join table: parts consumed during an intervention (with quantity).
model PartUsage {
  id             String @id @default(uuid()) @db.Uuid
  interventionId String @db.Uuid
  partId         String @db.Uuid
  quantity       Int    @default(1)

  intervention Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  part         Part         @relation(fields: [partId], references: [id])

  @@unique([interventionId, partId])
  @@map("part_usages")
}

// ── Preventive maintenance ───────────────────────────────────────────────────

model PlanRule {
  id           String   @id @default(uuid()) @db.Uuid
  siteId       String   @db.Uuid
  machineId    String   @db.Uuid
  title        String
  everyWeeks   Int
  technicianId String?  @db.Uuid
  duration     Float
  nextDue      DateTime @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site          Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  machine       Machine        @relation(fields: [machineId], references: [id], onDelete: Cascade)
  interventions Intervention[]

  @@index([siteId, nextDue])
  @@map("plan_rules")
}

// ── Files (Supabase Storage references) ──────────────────────────────────────

model Attachment {
  id             String   @id @default(uuid()) @db.Uuid
  // Storage path inside the Supabase bucket; never a public URL.
  storagePath    String
  kind           String // photo | signature | report
  mimeType       String
  faultId        String?  @db.Uuid
  interventionId String?  @db.Uuid
  createdAt      DateTime @default(now())

  fault        Fault?        @relation(fields: [faultId], references: [id], onDelete: Cascade)
  intervention Intervention? @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@index([faultId])
  @@index([interventionId])
  @@map("attachments")
}

// ── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String            @id @default(uuid()) @db.Uuid
  siteId    String            @db.Uuid
  level     NotificationLevel
  text      String
  read      Boolean           @default(false)
  createdAt DateTime          @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, read])
  @@map("notifications")
}
